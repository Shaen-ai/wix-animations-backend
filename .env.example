APP_NAME="Site Animation API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:4000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=site_animation
DB_USERNAME=root
DB_PASSWORD=

# For SQLite (no MySQL): DB_CONNECTION=sqlite, DB_DATABASE=database/database.sqlite

# Wix app (webhooks)
WIX_APP_ID=
WIX_APP_SECRET=
WIX_PUBLIC_KEY=

# Site Notice Banner OAuth (optional - uses default app id if not set)
SITE_NOTICE_BANNER_APP_ID=
SITE_NOTICE_BANNER_APP_SECRET=
